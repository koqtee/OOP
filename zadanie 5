WITH monthly_repairs AS (
    -- Шаг 1: Агрегируем общее количество ремонтных заявок по месяцам
    SELECT 
        DATE_TRUNC('month', created_at) AS repair_month,
        COUNT(request_id) AS repairs_count
    FROM repair_requests
    GROUP BY DATE_TRUNC('month', created_at)
)
-- Шаг 2: Применяем оконный фрейм для расчета среднего за 3 месяца
SELECT 
    TO_CHAR(repair_month, 'YYYY-MM') AS month,
    repairs_count,
    ROUND(
        AVG(repairs_count) OVER(
            ORDER BY repair_month 
            -- Рамка окна: текущая строка + 2 строки перед ней (итого 3 месяца)
            ROWS BETWEEN 2 PRECEDING AND CURRENT ROW
        ), 2
    ) AS rolling_avg_3_months
FROM monthly_repairs
ORDER BY repair_month;

