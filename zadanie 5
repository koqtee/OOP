SELECT 
    device_id,
    replacement_date AS current_replacement_date,
    -- Функция LAG «подтягивает» значение даты из предыдущей строки этого же устройства
    LAG(replacement_date) OVER(
        PARTITION BY device_id 
        ORDER BY replacement_date
    ) AS previous_replacement_date,
    -- Сразу вычисляем чистую разницу (сколько дней/времени прошло между замен)
    replacement_date - LAG(replacement_date) OVER(
        PARTITION BY device_id 
        ORDER BY replacement_date
    ) AS time_passed_since_last_time
FROM device_consumable_log
ORDER BY device_id, replacement_date;



