CREATE INDEX idx_log_date_device 
ON device_consumable_log (replacement_date, device_id, employee_id);

-- 2. Составной индекс на устройства: для ускорения фильтрации по типу и статусу техники
CREATE INDEX idx_devices_type_status 
ON devices (device_type, status);

-- 3. Индекс на сотрудников для мгновенной фильтрации по отделу
CREATE INDEX idx_employees_dept_emp 
ON employees (department_id, emp_id);


